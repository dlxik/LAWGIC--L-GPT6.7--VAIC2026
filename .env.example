# LLM: FPT AI Marketplace (OpenAI-compatible). Lấy key ở marketplace.fptcloud.com
# Dự án đã chuyển từ Anthropic sang FPT vì đó là key team có. Xem backend/core/llm.py.
LLM_PROVIDER=fpt
LLM_API_KEY=sk-...
LLM_BASE_URL=https://mkp-api.fptcloud.com
LLM_MODEL=Llama-3.3-70B-Instruct
LLM_EFFORT=high

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lawgic-dev-password

TREND_MIN_OCCURRENCES=5
TREND_WINDOW_HOURS=48
