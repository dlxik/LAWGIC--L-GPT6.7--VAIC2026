# LLM — FPT AI Marketplace (tuong thich OpenAI SDK)
# Lay key o marketplace.fptcloud.com. Doi nha cung cap = doi 3 bien nay
# + LLM_MODEL, khong dong vao code (xem backend/core/llm.py).
LLM_BASE_URL=https://mkp-api.fptcloud.com
LLM_API_KEY=sk-...
LLM_MODEL=gpt-oss-20b
# Cac model khac da benchmark: Llama-3.3-70B-Instruct (P1's winner), gemma-4-31B-it,
# SaoLa3.1-medium, gpt-oss-120b (P3 verdict engine).

# Neo4j (docker-compose khoi tao credentials theo bien duoi)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lawgic-dev-password

# Detect-trends window (P3)
TREND_MIN_OCCURRENCES=5
TREND_WINDOW_HOURS=48

# Rate limit (backend/api/ratelimit.py)
# 0 = KHONG trust X-Forwarded-For (mac dinh, an toan cho localhost).
# 1 = trust XFF (chi bat khi API dat sau reverse proxy da whitelist IP).
RATELIMIT_TRUST_XFF=0
