.env
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
node_modules/
.DS_Store

# ---------------------------------------------------------------------------
# Dữ liệu: mặc định KHÔNG vào git (nặng, sinh lại được), trừ dữ liệu demo.
#
# BẪY GITIGNORE: không thể mở lại một file nằm trong thư mục đã bị loại — git
# không buồn đi vào thư mục bị loại. Nên phải mở lại THƯ MỤC trước, rồi mới loại
# nội dung, rồi mới mở lại đúng file cần. Thứ tự các dòng dưới là bắt buộc.
#
# Vì sao dữ liệu demo phải vào git: cả team pull về phải có CÙNG một bộ. Chạy
# lại crawl/LLM ra kết quả khác -> node_id lệch -> graph mỗi máy một kiểu ->
# không ai debug được.
# ---------------------------------------------------------------------------

# Văn bản pháp luật: .docx gốc (P1)
data/raw/*
!data/raw/legal_docs/
data/raw/legal_docs/*
!data/raw/legal_docs/*.docx

# JSON đã cấu trúc hoá Điều-Khoản-Điểm (P1)
data/processed/*
!data/processed/legal_docs_structured/
data/processed/legal_docs_structured/*
!data/processed/legal_docs_structured/*.json

# Entity trích bằng LLM — output extractor.py (P1). Dẫn xuất từ văn bản QPPL công
# khai -> KHÔNG chứa dữ liệu cá nhân. Commit để P2 nạp graph mà không phải chạy
# lại ~38 phút LLM, và để mọi người dùng CÙNG một bộ entity.
!data/processed/entities_qlt2019.json
!data/processed/entities_qlt2025.json
!data/processed/entities_tncn2025.json

# ⚠️ CẢNH BÁO QUYỀN RIÊNG TƯ (teammate P3 nêu, giữ nguyên):
# File này chứa 3.321 bình luận của NGƯỜI THẬT. author_hash là GIẢ DANH, KHÔNG
# phải ẩn danh — mở `url` rồi tìm `content` là ra tên thật. Repo đang PUBLIC.
# Xem crawl_docs.md mục Quyền riêng tư. Cân nhắc để repo private trước khi nộp.
!data/raw/social_posts.json

!data/**/.gitkeep

# Cache embedding: COMMIT bản chuẩn (7.4MB) để fresh clone chạy Q&A ngay, không phải
# rebuild qua FPT (chậm, cần API key) và tránh "mỗi máy embed ra vector khác".
!data/processed/law_embeddings.npz

# P3 scratch (chẩn đoán eval — không vào git).
eval/_diag*.py
eval/_diag*.txt
eval/_diag_cache.json
eval/_last_run.txt
eval/_last_run*.txt
eval/_scoped*
eval/_pipeline_run.txt
eval/_last_run_graph.txt
eval/_scoped2*
eval/_ablate*
eval/_run_*.txt
eval/*.jsonl.bak

# coverage
.coverage
htmlcov/
